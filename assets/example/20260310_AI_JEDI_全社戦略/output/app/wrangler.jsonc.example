{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "replace-with-project-slug",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-09",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "vars": {
    "APP_ENV": "development"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "replace-with-d1-name",
      "migrations_dir": "./migrations"
    }
  ],
  "env": {
    "staging": {
      "name": "replace-with-project-slug-staging",
      "vars": {
        "APP_ENV": "staging"
      }
    },
    "production": {
      "name": "replace-with-project-slug",
      "workers_dev": false,
      "vars": {
        "APP_ENV": "production"
      }
    }
  }
}
